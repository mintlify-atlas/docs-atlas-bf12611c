  "keyFeatures": [
    "Flexbox-based responsive grid system with row and cell primitives",
    "Expressive parenthesis-style utility class syntax (e.g. tg-mode(auto))",
    "Responsive variants for every class via breakpoint prefixes (xs:, sm:, md:, lg:, xl:)",
    "12-column and 16-column span systems",
    "Fractional cell sizing (1/2, 1/3, 1/4, 2/3)",
    "Five gap sizes (none, xs, sm, md, lg, xl) with per-axis control",
    "Flexbox positioning and spacing utilities (pos, pos-x, pos-y, space, space-x, space-y)",
    "Container with responsive max-width breakpoints",
    "Minimal CSS reset (tidiness) included",
    "SCSS source with configurable namespaces, breakpoints, and syntax"
  ],
  "publicApiSurface": [
